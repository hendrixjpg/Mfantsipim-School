{
  "entities": {
    "NewsItem": {
      "title": "News Item",
      "description": "A news article or school update",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Headline of the news" },
        "content": { "type": "string", "description": "Full content of the article" },
        "date": { "type": "string", "format": "date-time", "description": "Publication date" },
        "imageUrl": { "type": "string", "description": "URL of the cover image" },
        "category": { "type": "string", "enum": ["Academic", "Sports", "Alumni", "General", "Innovation"] },
        "author": { "type": "string", "description": "Name of the author" },
        "authorUid": { "type": "string", "description": "UID of the admin who posted" }
      },
      "required": ["title", "content", "date", "category", "author", "authorUid"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "A school award or milestone",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "year": { "type": "string" },
        "category": { "type": "string", "enum": ["Academic", "Sports", "Arts", "Innovation"] }
      },
      "required": ["title", "description", "year", "category"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "House points for the leaderboard",
      "type": "object",
      "properties": {
        "houseName": { "type": "string" },
        "points": { "type": "integer" },
        "rank": { "type": "integer" }
      },
      "required": ["houseName", "points"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "alumni", "student", "guest"] },
        "graduationYear": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/news": {
      "schema": { "$ref": "NewsItem" },
      "description": "Collection of school news articles"
    },
    "/achievements": {
      "schema": { "$ref": "Achievement" },
      "description": "Collection of school achievements"
    },
    "/leaderboard": {
      "schema": { "$ref": "LeaderboardEntry" },
      "description": "Collection of house points"
    },
    "/users": {
      "schema": { "$ref": "UserProfile" },
      "description": "Collection of user profiles"
    }
  }
}
